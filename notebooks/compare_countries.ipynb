   "source": [
    "countries = [\"ethiopia\", \"kenya\", \"uganda\", \"tanzania\", \"somalia\"]\n",
    "\n",
    "dfs = []\n",
    "\n",
    "for c in countries:\n",
    "    df = pd.read_csv(f\"data/{c}_clean.csv\")\n",
    "    df[\"Country\"] = c.capitalize()\n",
    "    dfs.append(df)\n",
    "\n",
    "data = pd.concat(dfs, ignore_index=True)\n",
    "\n",
    "data.head()"
   ]
  }
